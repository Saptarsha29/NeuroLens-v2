# Preferred: Firebase service account JSON as a single-line string.
# For local .env usage, replace line breaks in private_key with \n.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional fallback for local development only (file must not be committed)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Allowed CORS origins (comma-separated)
# Dev: http://localhost:5173
# Prod: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Gmail SMTP (required for real email verification delivery)
GMAIL_SENDER_EMAIL=
GMAIL_SENDER_PASSWORD=
GMAIL_SMTP_SERVER=smtp.gmail.com
GMAIL_SMTP_PORT=587

# Verification policy
VERIFICATION_CODE_EXPIRY_MINUTES=10
VERIFICATION_MAX_ATTEMPTS=5
